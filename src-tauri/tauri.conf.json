{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Clinical Reference",
  "version": "1.0.0",
  "identifier": "com.clinicalreference.hub",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clinical Reference",
        "width": 1280,
        "height": 860,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage"],
    "category": "Education",
    "shortDescription": "Integrated clinical reference hub",
    "longDescription": "An integrated clinical reference spanning nine musculoskeletal, osteopathic and diagnostic compendia.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
